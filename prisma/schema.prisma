generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ItemType {
  SALE
  LOST
  FOUND
}

enum ItemStatus {
  ACTIVE
  RESERVED
  SOLD
  ARCHIVED
}

model User {
  id    String  @id @default(cuid())
  email String  @unique
  name  String?
  posts Post[]
  items Item[]
}

model Post {
  id        String  @id @default(cuid())
  title     String
  content   String?
  published Boolean @default(false)
  authorId  String
  author    User    @relation(fields: [authorId], references: [id])
}

model Item {
  id          String     @id @default(cuid())
  title       String
  description String
  category    String
  condition   String
  price       Float?
  imageUrls   String[]
  type        ItemType
  status      ItemStatus
  postedById  String
  postedBy    User       @relation(fields: [postedById], references: [id])
}
